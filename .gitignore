# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — version00 (Gradle / Spring Boot)
# ══════════════════════════════════════════════════════════════════════════════

# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ── IntelliJ IDEA ─────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ── Eclipse ───────────────────────────────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── NetBeans ──────────────────────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux ─────────────────────────────────────────────────────────────────────
*~

# ── Java ──────────────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ── Spring Boot ───────────────────────────────────────────────────────────────
# Archivos de configuración con secretos (NUNCA commitear)
application-local.yml
application-local.properties
application-secrets.yml
application-secrets.properties

# ── Secretos y credenciales ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
secrets/
credentials/

# ── Docker ────────────────────────────────────────────────────────────────────
# No ignorar Dockerfile ni docker-compose.yml (son parte del proyecto)
# Ignorar archivos de override locales
docker-compose.override.yml
docker-compose.local.yml

# ── Reportes de tests y cobertura (generados automáticamente) ─────────────────
# JaCoCo
build/reports/jacoco/
build/jacoco/

# Pitest
build/reports/pitest/

# Cucumber
build/cucumber-reports/

# Surefire / test results
build/test-results/

# ── Reportes de seguridad (generados por Snyk/SonarQube) ─────────────────────
snyk.sarif
.snyk
sonar-project.properties.bak

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
spring.log

# ── Archivos temporales ───────────────────────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
*~
tmp/
temp/

# ── Kubernetes — secretos reales (NUNCA commitear valores reales) ─────────────
# La plantilla k8s/secret.yaml SÍ se commitea (sin valores reales)
k8s/*-secret-values.yaml
k8s/*.sealed.yaml
